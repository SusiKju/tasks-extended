rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Hilfsfunktionen ────────────────────────────────────────────────────────

    // Ist der anfragende User in dieser Familie Mitglied?
    function isFamilyMember(familyId) {
      return request.auth != null
          && exists(/databases/$(database)/documents/families/$(familyId)/members/$(request.auth.uid));
    }

    // Ist der anfragende User eingeloggt?
    function isSignedIn() {
      return request.auth != null;
    }

    // ── userFamilies: schnelle Familien-Nachschlag pro User ────────────────────
    // Nur der User selbst darf seinen eigenen Eintrag lesen/schreiben.
    match /userFamilies/{uid} {
      allow read, write: if isSignedIn() && request.auth.uid == uid;
    }

    // ── familyCodes: Beitrittscode-Lookup ─────────────────────────────────────
    // Jeder eingeloggte User darf einen Code lesen (zum Beitreten).
    // Erstellt wird der Code nur beim createFamily – kein direktes Schreiben durch User.
    match /familyCodes/{code} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if false; // Codes sind unveränderlich
    }

    // ── Familie (Hauptstruktur) ────────────────────────────────────────────────
    match /families/{familyId} {

      // Meta-Dokument: alle Mitglieder lesen, kein direktes Schreiben
      allow read: if isFamilyMember(familyId);
      allow create: if isSignedIn(); // createFamily schreibt das erste Mal
      allow update: if isFamilyMember(familyId);
      allow delete: if false;

      // Mitglieder-Liste
      match /members/{uid} {
        // Mitglieder lesen alle; User darf eigenes Dokument lesen (z.B. beim Beitreten prüfen)
        allow read: if isFamilyMember(familyId) || (isSignedIn() && request.auth.uid == uid);
        // Mitglied darf sich selbst hinzufügen (joinFamily) und entfernen (leaveFamily)
        allow create: if isSignedIn() && request.auth.uid == uid;
        allow delete: if isSignedIn() && request.auth.uid == uid;
        allow update: if isFamilyMember(familyId) || (isSignedIn() && request.auth.uid == uid);
      }

      // Kinder-Konfiguration (addChild, updateChild, deleteChild)
      match /childrenConfig/{childId} {
        allow read, write: if isFamilyMember(familyId);
      }

      // Kinder-Aufgaben, Aktivitätslog, pushToken, Belohnung
      match /children/{childId} {
        allow read, write: if isFamilyMember(familyId);

        match /tasks/{taskId} {
          allow read, write: if isFamilyMember(familyId);
        }

        match /activity/{entryId} {
          allow read, write: if isFamilyMember(familyId);
        }
      }

      // Push-Trigger (Eltern → Kind)
      match /pushTriggers/{childId} {
        allow read, write: if isFamilyMember(familyId);
      }

      // App-Konfiguration (Erinnerungszeiten)
      match /config/{docId} {
        allow read, write: if isFamilyMember(familyId);
      }

      // Geteilte Notizliste + Countdowns
      match /shared/{document=**} {
        allow read, write: if isFamilyMember(familyId);
      }

      // Persönlicher Scratchpad pro User
      match /scratchpadByUser/{uid} {
        allow read, write: if isFamilyMember(familyId) && request.auth.uid == uid;
      }

      // "Mein Tag"-Feed: manuelle Sortierung pro User
      match /feedOrderByUser/{uid} {
        allow read, write: if isFamilyMember(familyId) && request.auth.uid == uid;
      }

      // App-Settings pro User (TE-49)
      match /settingsByUser/{uid} {
        allow read, write: if isFamilyMember(familyId) && request.auth.uid == uid;
      }

      // E-Mail-Pins pro User (TE-50)
      match /mailPinsByUser/{uid} {
        allow read, write: if isFamilyMember(familyId) && request.auth.uid == uid;
      }

      // Persönliche Notizen pro User
      match /personalNotesByUser/{uid}/notes/{noteId} {
        allow read, write: if isFamilyMember(familyId) && request.auth.uid == uid;
      }

      // Persönliche Gedanken-Kacheln pro User
      match /geistesKachelByUser/{uid}/tiles/{tileId} {
        allow read, write: if isFamilyMember(familyId) && request.auth.uid == uid;
      }

      // Persönliche Linkliste pro User (TE-32)
      match /linksByUser/{uid}/links/{linkId} {
        allow read, write: if isFamilyMember(familyId) && request.auth.uid == uid;
      }
    }

    // ── Fokus-Kachel: strikt privat pro User, nicht geteilt (TE-7/TE-10/TE-12) ──
    // Bewusst außerhalb von families/: keine Familienmitgliedschaft nötig,
    // ausschließlich der Eigentümer (uid) darf lesen/schreiben.
    match /focusTilesByUser/{uid}/themes/{theme} {
      allow read, write: if isSignedIn() && request.auth.uid == uid;
    }

    // ── Bambini-Kinder-Registry: strikt privat pro User (TE-18) ───────────────
    // Genau wie focusTilesByUser bewusst außerhalb von families/.
    match /bambiniByUser/{uid} {
      allow read, write: if isSignedIn() && request.auth.uid == uid;
    }

    // ── Alle anderen Dokumente: kein Zugriff ──────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
